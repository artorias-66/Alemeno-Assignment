    <mxCell id="l1_b2" value="" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="l1_bg2" target="l1_bg3" parent="l1_bg"><mxGeometry relative="1" as="geometry" /></mxCell>
