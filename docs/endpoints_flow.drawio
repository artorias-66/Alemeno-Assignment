      vertex="1" parent="l1_bg">
      <mxGeometry x="65" y="304" width="200" height="34" as="geometry" />
    </mxCell>

    <!-- Lane 1 arrows (sync section) -->
    <mxCell id="l1_e1" value="" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="l1_c"  target="l1_v"  parent="lane1"><mxGeometry relative="1" as="geometry" /></mxCell>
