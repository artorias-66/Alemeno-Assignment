    <mxCell id="l1_b4" value="" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="l1_bg4" target="l1_bg5" parent="l1_bg"><mxGeometry relative="1" as="geometry" /></mxCell>

