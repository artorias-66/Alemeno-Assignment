<?xml version="1.0" encoding="UTF-8"?>
<!--
  Endpoint Flow Diagram — AI-Powered Transaction Processing Pipeline
  Four vertical swimlane columns, one per endpoint.
  All arrows are strictly vertical within each lane; no cross-lane routing.
  Open at: https://app.diagrams.net
-->
<mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1"
              connect="1" arrows="1" fold="1" page="1" pageScale="1"
              pageWidth="1700" pageHeight="1000" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- TITLE                                                         -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <mxCell id="title"
      value="API Endpoint Flow — AI-Powered Transaction Processing Pipeline"
      style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;"
      vertex="1" parent="1">
      <mxGeometry x="150" y="18" width="1380" height="36" as="geometry" />
    </mxCell>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- LANE 1 — POST /jobs/upload                                   -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <mxCell id="lane1"
      value="POST /jobs/upload"
      style="swimlane;startSize=36;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;horizontal=1;"
      vertex="1" parent="1">
      <mxGeometry x="20" y="64" width="370" height="870" as="geometry" />
    </mxCell>

    <mxCell id="l1_c" value="Client"
      style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;"
