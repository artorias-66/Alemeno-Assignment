      <mxGeometry x="135" y="52" width="100" height="40" as="geometry" />
    </mxCell>

    <mxCell id="l1_v" value="Validate .csv extension"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#555;fontSize=11;"
      vertex="1" parent="lane1">
      <mxGeometry x="85" y="125" width="200" height="36" as="geometry" />
    </mxCell>

    <mxCell id="l1_s" value="Save file to /app/uploads"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#555;fontSize=11;"
      vertex="1" parent="lane1">
      <mxGeometry x="85" y="195" width="200" height="36" as="geometry" />
    </mxCell>

    <mxCell id="l1_db" value="Create Job record (status=pending)"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#555;fontSize=11;"
